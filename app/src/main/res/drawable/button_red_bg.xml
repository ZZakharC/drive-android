<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Отключенное состояние -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#2A2A2A" />
            <stroke android:width="1dp" android:color="@color/white_dark" />
            <corners android:radius="8dp" />
            <gradient
                android:angle="145"
                android:startColor="#2A2A2A"
                android:endColor="#1F1F1F" />
        </shape>
    </item>

    <!-- Нажатое состояние (active) – без тени и подъёма -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#5A5A5A" />
            <stroke android:width="1dp" android:color="@color/red" />
            <corners android:radius="8dp" />
            <gradient
                android:angle="145"
                android:startColor="#5A5A5A"
                android:endColor="#3F3F3F" />
        </shape>
    </item>

    <!-- Обычное состояние -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A2A2A" />
            <stroke android:width="1dp" android:color="@color/red" />
            <corners android:radius="8dp" />
            <gradient
                android:angle="145"
                android:startColor="#2A2A2A"
                android:endColor="#1F1F1F" />
        </shape>
    </item>
</selector>